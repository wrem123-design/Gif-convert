{
  "name": "@sprite-forge/core",
  "version": "1.0.4",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --out-dir dist",
    "dev": "tsup src/index.ts --dts --format esm,cjs --out-dir dist --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.3.0",
    "gif-encoder-2": "^1.0.5",
    "gifuct-js": "^2.1.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
